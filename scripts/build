#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Load app metadata
source "$ROOT_DIR/APP_METADATA"

# Check for vcpkg
if [[ -z "${VCPKG_ROOT:-}" ]]; then
    if [[ -d "$HOME/vcpkg" ]]; then
        export VCPKG_ROOT="$HOME/vcpkg"
    else
        echo "Error: vcpkg not found. Install it with:"
        echo "  git clone https://github.com/microsoft/vcpkg.git ~/vcpkg"
        echo "  ~/vcpkg/bootstrap-vcpkg.sh"
        exit 1
    fi
fi
echo "Using vcpkg at: $VCPKG_ROOT"

# Parse arguments
BUILD_TYPE="Debug"
BUILD_DIR="$ROOT_DIR/build"
RECONFIGURE=false
for arg in "$@"; do
    case "$arg" in
        release) BUILD_TYPE="Release"; BUILD_DIR="$ROOT_DIR/build_release" ;;
        --reconfigure) RECONFIGURE=true ;;
    esac
done
BUILD_DIR="${BUILD_DIR_OVERRIDE:-$BUILD_DIR}"
GENERATOR="${CMAKE_GENERATOR:-Unix Makefiles}"

# Only run cmake configure if build dir doesn't exist or CMakeCache is missing
if [[ ! -f "$BUILD_DIR/CMakeCache.txt" ]] || [[ "$RECONFIGURE" == true ]]; then
    echo "Configuring CMake (${BUILD_TYPE}, ${GENERATOR})..."
    cmake -S "$ROOT_DIR" -B "$BUILD_DIR" -G "$GENERATOR" -DCMAKE_BUILD_TYPE="$BUILD_TYPE"
else
    echo "Skipping CMake configure (already configured). Use --reconfigure to force."
fi

echo "Building DearAPI..."
cmake --build "$BUILD_DIR" --target dearapi --parallel

echo "Build complete: $BUILD_DIR/dearapi"
